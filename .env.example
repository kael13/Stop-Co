# Copy this file to .env and fill in your values
# API Base URLs
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OSRM_BASE_URL=https://router.project-osrm.org
TILE_URL_TEMPLATE=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# App
APP_NAME=Stop-Co
USER_AGENT=StopCo/1.0
PACKAGE_NAME=com.stopco.app

# Platform Channels
FOREGROUND_CHANNEL=com.stopco.app/foreground_service
ALARM_CHANNEL=com.stopco.app/alarm

# Notification Channels
ALARM_CHANNEL_ID=stop_co_alarm
ALARM_CHANNEL_NAME=Destination Alarm
ALARM_CHANNEL_DESC=Alerts when approaching your destination
